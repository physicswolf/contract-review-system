APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
API_PREFIX=/api
UPLOAD_DIR=storage/uploads
PARSING_DIR=storage/parsing
MAX_UPLOAD_SIZE_MB=50
DOCX_PARSER_ENGINE=docling
PDF_PARSER_ENGINE=docling
JWT_SECRET_KEY=change-me-in-production-32-byte-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
ENABLE_STRUCTURE_EDITOR=false

# MySQL 连接参数
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=aizhiqi
